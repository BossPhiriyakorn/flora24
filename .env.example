# ============================================================
#  FLORA 24/7 EXPRESS — Environment Variables Template
#  คัดลอกไฟล์นี้เป็น .env.local แล้วกรอกค่าจริง
#  ห้าม commit .env.local เข้า git เด็ดขาด
# ============================================================


# ─────────────────────────────────────────
#  APP
# ─────────────────────────────────────────
NEXT_PUBLIC_APP_URL="https://listening-there-margin-replaced.trycloudflare.com"
# Tunnel เปลี่ยนทุกครั้งที่รัน cloudflared — ใส่ URL ปัจจุบัน หรือหลาย URL คั่นด้วย comma ที่ NEXT_PUBLIC_ALLOWED_ORIGINS
# NEXT_PUBLIC_ALLOWED_ORIGINS="https://surface-exists-second-deserve.trycloudflare.com,https://listening-there-margin-replaced.trycloudflare.com"
# Production: เปลี่ยนเป็น https://yourdomain.com


# ─────────────────────────────────────────
#  MONGODB
# ─────────────────────────────────────────
# รูปแบบ: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
# Direct connection (ไม่ใช้ SRV DNS — แก้ปัญหา True Internet block SRV queries)
MONGODB_URI="mongodb://USER:PASSWORD@cluster.mongodb.net/flora_db?retryWrites=true&w=majority"
MONGODB_DB_NAME="flora_db"
# โหมด dev ใช้ TLS workaround เป็นค่าเริ่มต้น (ยกเลิกด้วย MONGODB_TLS_INSECURE=0)
# ถ้าเจอ ERR_SSL_TLSV1_ALERT_INTERNAL_ERROR บน Windows ให้ใส่ 1
# MONGODB_TLS_INSECURE=1
# ใช้ Google DNS สำหรับเชื่อม Atlas (แก้ปัญหา DNS/SSL บางเครือข่าย — ตอน Deploy ไม่ต้องตั้ง)
# MONGODB_USE_GOOGLE_DNS=1


# ─────────────────────────────────────────
#  LINE LOGIN (OAuth 2.0)
# ─────────────────────────────────────────
# สร้างที่: https://developers.line.biz/console/
# ประเภท: LINE Login Channel
LINE_CLIENT_ID="YOUR_LINE_CHANNEL_ID"
LINE_CLIENT_SECRET="YOUR_LINE_CHANNEL_SECRET"
# Callback URL ที่ต้องกรอกใน LINE Console:
# http://localhost:3000/api/auth/callback/line  (dev)
# https://yourdomain.com/api/auth/callback/line  (prod)

# JWT Secret สำหรับ USER (สุ่มอักขระ 32+ ตัว)
JWT_SECRET="your-jwt-secret-min-32-chars"
JWT_EXPIRES_IN="7d"                             # อายุ token: 7d | 30d | 1h ฯลฯ

# JWT Secret สำหรับ ADMIN — ต้องต่างจาก JWT_SECRET เด็ดขาด
# cookie admin จะมี path=/admin และใช้ secret คนละตัว
# ป้องกัน user token ปลอมตัวเป็น admin ได้อย่างสมบูรณ์
JWT_ADMIN_SECRET="your-admin-jwt-secret-different-from-above"


# =============================================================================
# Email Configuration (Brevo SMTP)
# =============================================================================
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=tony@tectony.co.th
SMTP_PASS=your-brevo-smtp-key

# อีเมลและชื่อที่แสดงในหัวจดหมาย "จาก" (ควรเป็นโดเมนที่ยืนยันใน Brevo แล้ว)
EMAIL_FROM=no-reply@tectony.co.th
EMAIL_FROM_NAME=Flora 24/7 Express

# OTP Settings
OTP_EXPIRY_MINUTES=5
OTP_COOLDOWN_MINUTES=5
OTP_CODE_LENGTH=6
MAX_OTP_ATTEMPTS=5


# ============================================================
#  PAYMENT GATEWAY — บัตรเครดิต/เดบิต ตัดเงินอัตโนมัติ
# ============================================================
#
# เปิดใช้เมื่อใส่ Publishable Key + Secret Key จาก Dashboard
# ดูรายละเอียด: docs/PAYMENT_GATEWAY_SETUP.md
PAYMENT_GATEWAY_ENABLED=true
PAYMENT_GATEWAY_PUBLIC_KEY="pk_test_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"
# คีย์เดียวกัน — ต้องมี NEXT_PUBLIC_ เพื่อให้ frontend (Stripe.js) ใช้ยืนยันบัตร
NEXT_PUBLIC_PAYMENT_GATEWAY_PUBLIC_KEY="pk_test_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"
PAYMENT_GATEWAY_SECRET_KEY="sk_test_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"
#
# Webhook / Callback URLs (ต้องเป็น HTTPS — ใช้ ngrok ตอน dev)
# Webhook Secret — ได้จาก: stripe listen --print-secret  (dev) หรือ Stripe Dashboard (prod)
PAYMENT_GATEWAY_WEBHOOK_SECRET="whsec_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"
PAYMENT_GATEWAY_SUCCESS_URL="https://yourdomain.com/checkout/success"
PAYMENT_GATEWAY_CANCEL_URL="https://yourdomain.com/checkout/cancel"
PAYMENT_GATEWAY_NOTIFY_URL="https://yourdomain.com/api/payment/notify"


# ─────────────────────────────────────────
#  GOOGLE DRIVE — เชื่อมด้วยไอดีทั้งหมด
# ─────────────────────────────────────────
GOOGLE_DRIVE_CREDENTIALS_PATH="./Credentials.json"

# ใส่ไอดีโฟลเดอร์จาก URL: https://drive.google.com/.../folders/XXXXXXXX
GOOGLE_DRIVE_ROOT_FOLDER_ID=""
GOOGLE_DRIVE_ROOT_FOLDER_NAME="Flora"

# ไอดีโฟลเดอร์ 3 ตัว (articles, products, user-profiles) — ใส่ให้ครบ แชร์ให้ Service Account
GOOGLE_DRIVE_FOLDER_USER_PROFILES=""   # user-profiles
GOOGLE_DRIVE_FOLDER_PRODUCTS=""       # products
GOOGLE_DRIVE_FOLDER_ARTICLES=""       # articles
# ระบบใช้ไอดีเชื่อมตรง — สร้างเฉพาะย่อยในย่อย: userId, productId, articleId


# ─────────────────────────────────────────
#  NOTES (ไม่ใส่ใน .env — ดูได้ที่นี่)
# ─────────────────────────────────────────
# LINE Login Scopes ที่ต้องการ: profile, openid, email
# MongoDB ตอน Deploy: ตั้ง Atlas → Network Access → Allow access from anywhere (0.0.0.0/0) ไม่ผูก IP
#   ดูรายละเอียด: docs/DEPLOY.md
# PaySolutions/Stripe: webhook URL ต้องเป็น HTTPS (ใช้โดเมน ไม่ใช้ IP)
#
# วิธีเชื่อม Credentials.json กับ .env:
#   - วางไฟล์ Credentials.json ที่ root โปรเจกต์ แล้วตั้ง GOOGLE_DRIVE_CREDENTIALS_PATH=./Credentials.json
#   - บน Linux ชื่อไฟล์ต้องตรงตัวพิมพ์ (Credentials.json ไม่ใช่ credentials.json)
#   - ตอน deploy (เช่น standalone): ใช้ path แบบ absolute เช่น GOOGLE_DRIVE_CREDENTIALS_PATH=/home/ubuntu/flora/standalone/Credentials.json
#   - หรือคัดลอกค่าใน JSON ไปใส่ .env แบบ GOOGLE_DRIVE_CREDENTIALS_JSON='{"type":"service_account",...}'
#     (ใน private_key ต้องใช้ \n แทนบรรทัดใหม่)
#   - ฟิลด์ใน Credentials.json: type, project_id, private_key_id, private_key, client_email, client_id, auth_uri, token_uri ฯลฯ
#     โปรเจกต์นี้ใช้ทั้งก้อนจากไฟล์/สตริง ไม่ต้องแยกใส่ .env ทีละฟิลด์
