# ============================================================
#  FLORA — Production .env (วางบนเซิร์ฟเวอร์ที่ /home/ubuntu/flora/standalone/.env)
#  คัดลอกไปแก้ค่าจริง แล้วอัปโหลดหรือ nano บนเซิร์ฟเวอร์
#  ห้าม commit ไฟล์ .env จริงเข้า git
# ============================================================

NODE_ENV=production

# ─────────────────────────────────────────
#  APP (Production โดเมน)
# ─────────────────────────────────────────
NEXT_PUBLIC_APP_URL="https://flower.tectony.co.th"
# ถ้ามีหลาย origin (เช่น www) คั่นด้วย comma
# NEXT_PUBLIC_ALLOWED_ORIGINS="https://flower.tectony.co.th,https://www.flower.tectony.co.th"

# ─────────────────────────────────────────
#  MONGODB (ต้องเพิ่ม IP เซิร์ฟเวอร์ใน Atlas → Network Access ก่อน)
# ─────────────────────────────────────────
MONGODB_URI="mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/flora_db?retryWrites=true&w=majority"
MONGODB_DB_NAME="flora_db"

# ─────────────────────────────────────────
#  LINE LOGIN (Callback URL ใน LINE Console ต้องเป็น https://flower.tectony.co.th/api/auth/callback/line)
# ─────────────────────────────────────────
LINE_CLIENT_ID="YOUR_LINE_CHANNEL_ID"
LINE_CLIENT_SECRET="YOUR_LINE_CHANNEL_SECRET"

# JWT — ใช้ค่าสุ่มแข็งแรง ไม่ซ้ำกับ dev (อย่างน้อย 32 ตัวอักษร)
JWT_SECRET="ใส่ค่าสุ่มยาว-อย่างน้อย-32-ตัวอักษร"
JWT_EXPIRES_IN="7d"
JWT_ADMIN_SECRET="ใส่ค่าสุ่มอีกตัว-ต่างจาก-JWT_SECRET-เด็ดขาด"

# ─────────────────────────────────────────
#  Email (Brevo SMTP)
# ─────────────────────────────────────────
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-email
SMTP_PASS=your-brevo-smtp-key
EMAIL_FROM=no-reply@tectony.co.th
EMAIL_FROM_NAME=Flora 24/7 Express

OTP_EXPIRY_MINUTES=5
OTP_COOLDOWN_MINUTES=5
OTP_CODE_LENGTH=6
MAX_OTP_ATTEMPTS=5

# ─────────────────────────────────────────
#  Payment (Stripe) — Webhook URL ใน Stripe Dashboard = https://flower.tectony.co.th/api/payment/webhook
# ─────────────────────────────────────────
PAYMENT_GATEWAY_ENABLED=true
PAYMENT_GATEWAY_PUBLIC_KEY="pk_live_xxxx"
NEXT_PUBLIC_PAYMENT_GATEWAY_PUBLIC_KEY="pk_live_xxxx"
PAYMENT_GATEWAY_SECRET_KEY="sk_live_xxxx"
PAYMENT_GATEWAY_WEBHOOK_SECRET="whsec_xxxx"
PAYMENT_GATEWAY_SUCCESS_URL="https://flower.tectony.co.th/checkout?success=1"
PAYMENT_GATEWAY_CANCEL_URL="https://flower.tectony.co.th/checkout"
PAYMENT_GATEWAY_NOTIFY_URL="https://flower.tectony.co.th/api/payment/notify"

# ─────────────────────────────────────────
#  Google Drive (ถ้าใช้ — ต้องวาง Credentials.json บนเซิร์ฟเวอร์ที่ path นี้ หรือใช้ GOOGLE_DRIVE_CREDENTIALS_JSON)
# ─────────────────────────────────────────
GOOGLE_DRIVE_CREDENTIALS_PATH="./Credentials.json"
GOOGLE_DRIVE_ROOT_FOLDER_ID=""
GOOGLE_DRIVE_ROOT_FOLDER_NAME="Flora"
GOOGLE_DRIVE_FOLDER_USER_PROFILES=""
GOOGLE_DRIVE_FOLDER_PRODUCTS=""
GOOGLE_DRIVE_FOLDER_ARTICLES=""
